# Telegram bot token — get this from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# Google Sheet ID — the string between /d/ and /edit in your Sheet URL
SHEET_ID=your_google_sheet_id_here

# Google service account credentials (paste entire JSON as a single line)
# Get this from Google Cloud Console → IAM & Admin → Service Accounts → Keys
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Alternative: path to credentials JSON file (use instead of GOOGLE_CREDENTIALS_JSON if preferred)
# GOOGLE_CREDENTIALS_PATH=./credentials.json

# Q2 start date — don't change this
Q2_START_DATE=2026-04-13
